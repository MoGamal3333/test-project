# Dependencies
node_modules/

# Logs
logs/
*.log

# Runtime data
pids
*.pid
*.seed

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage/

# Grunt intermediate storage
.grunt

# Compiled binary addons
build/Release

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# VULNERABILITY: .env file NOT in gitignore - secrets will be committed!
# .env

# VULNERABILITY: config files with secrets NOT ignored
# config/database.js

# VULNERABILITY: terraform state files NOT ignored
# *.tfstate
# *.tfstate.backup
# .terraform/

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# VULNERABILITY: Many sensitive files are not ignored, allowing secrets to be committed:
# - .env (contains all API keys and passwords)
# - config/database.js (hardcoded credentials)
# - Terraform state files (contain sensitive outputs)
# - Kubernetes secrets
